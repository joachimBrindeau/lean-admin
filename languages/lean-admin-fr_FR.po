#: includes/AdminTweaks/AdminTweaksModule.php:170
msgid "Clean admin bar"
msgstr "Barre d’administration épurée"

#: includes/AdminTweaks/AdminTweaksModule.php:171
msgid "Remove the WordPress logo, comments, and new-content nodes from the admin bar."
msgstr "Retirer de la barre d’administration le logo WordPress, les commentaires et le bouton de création de contenu."

#: includes/AdminTweaks/AdminTweaksModule.php:189
msgid "Clean dashboard"
msgstr "Tableau de bord épuré"

#: includes/AdminTweaks/AdminTweaksModule.php:190
msgid "Remove the default dashboard widgets and the welcome panel."
msgstr "Supprimer les widgets par défaut du tableau de bord et le panneau de bienvenue."

#: includes/AdminTweaks/AdminTweaksModule.php:207
msgid "Clean admin footer"
msgstr "Pied de page d’administration épuré"

#: includes/AdminTweaks/AdminTweaksModule.php:208
msgid "Hide the WordPress version and the “Thank you for creating with WordPress” footer text."
msgstr "Masquer la version WordPress et le texte de pied de page « Thank you for creating with WordPress »."

#: includes/AdminTweaks/AdminTweaksModule.php:216
msgid "Hide comments UI"
msgstr "Masquer l’interface des commentaires"

#: includes/AdminTweaks/AdminTweaksModule.php:217
msgid "Remove the Comments menu and comment metaboxes from admin screens."
msgstr "Retirer des écrans d’administration le menu Commentaires et les boîtes de commentaires."

#: includes/AdminTweaks/AdminTweaksModule.php:238
msgid "Quiet LiteSpeed purge notices"
msgstr "Masquer les notifications de purge LiteSpeed"

#: includes/AdminTweaks/AdminTweaksModule.php:239
msgid "Suppress the “Purge url …” and “Purged all caches successfully.” admin notices from LiteSpeed Cache."
msgstr "Masquer les notifications d’administration « Purge url … » et « Purged all caches successfully. » de LiteSpeed Cache."

